<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools">

  <!-- Network -->
  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

  <!-- Storage (optional for future document translation) -->
  <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
  <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
    android:maxSdkVersion="32" />

  <!-- Clipboard -->
  <uses-permission android:name="android.permission.VIBRATE" />

  <!-- Audio (optional for TTS/STT) -->
  <uses-permission android:name="android.permission.RECORD_AUDIO" />

  <!-- Camera (optional for OCR) -->
  <uses-permission android:name="android.permission.CAMERA" />

  <!-- Runtime permissions handled by code -->

  <application
    android:name="com.xtranslate.App"
    android:allowBackup="false"
    android:dataExtractionRules="@xml/data_extraction_rules"
    android:debuggable="false"
    android:icon="@mipmap/ic_launcher"
    android:label="@string/app_name"
    android:roundIcon="@mipmap/ic_launcher_round"
    android:supportsRtl="true"
    android:theme="@style/Theme.XTranslate"
    android:usesCleartextTraffic="false"
    tools:targetApi="31">

    <!-- Main Activity -->
    <activity
      android:name="com.xtranslate.MainActivity"
      android:exported="true"
      android:label="@string/app_name"
      android:theme="@style/Theme.XTranslate">
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity>

    <!-- Share Intent Handler (future) -->
    <activity
      android:name="com.xtranslate.ShareActivity"
      android:exported="true"
      android:theme="@style/Theme.XTranslate">
      <intent-filter>
        <action android:name="android.intent.action.SEND" />
        <category android:name="android.intent.category.DEFAULT" />
        <data android:mimeType="text/plain" />
      </intent-filter>
    </activity>

    <!-- Services -->
    <service android:name="com.xtranslate.service.ClipboardMonitorService"
      android:exported="false"
      android:foregroundServiceType="dataSync" />

    <!-- Backup -->
    <meta-data
      android:name="com.google.android.backup.api"
      android:value="31" />
  </application>

</manifest>
